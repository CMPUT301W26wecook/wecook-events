<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_dialog_event_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event name"
        android:textColor="@color/text_dark"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_dialog_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Location"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_dialog_registration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Registration"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_dialog_organizer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Organizer"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_dialog_waitlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Waitlist"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_dialog_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:lineSpacingExtra="4dp"
        android:text="Description"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_join_waitlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Join the waiting list"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btn_close_dialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Close"
        android:textAllCaps="false" />

</LinearLayout>
